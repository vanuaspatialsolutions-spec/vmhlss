# Database Configuration
DB_PASSWORD=your_secure_password_here_change_in_production
REDIS_PASSWORD=your_redis_password_here_min_16_chars

# JWT Configuration
JWT_SECRET_KEY=your_jwt_secret_here_min_32_chars_change_in_production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Anthropic API Configuration
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Frontend Configuration
MAPLIBRE_STYLE_URL=https://demotiles.maplibre.org/style.json
VITE_API_URL=http://localhost:8000
VITE_MAPLIBRE_STYLE_URL=https://demotiles.maplibre.org/style.json
VITE_ENVIRONMENT=development

# Deployment Configuration (for Render.com)
RENDER_API_KEY=your_render_api_key_here
RENDER_SERVICE_ID=your_render_service_id_here
DOMAIN=localhost

# Application Environment
ENVIRONMENT=development
# Set to 'production' when deploying to Render or production servers
# Set to 'development' for local development

# File Upload Configuration
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=500

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
# For production, use specific domains: https://yourdomain.com,https://api.yourdomain.com

# Database URL (auto-generated in docker-compose, override if needed)
DATABASE_URL=postgresql://vmhlss_user:${DB_PASSWORD}@db:5432/vmhlss

# Redis Configuration
REDIS_URL=redis://redis:6379

# Logging Configuration
LOG_LEVEL=info
# Options: debug, info, warning, error, critical

# Server Configuration
WORKERS=4
# Number of uvicorn/gunicorn workers for backend

# Email Configuration (optional, for notifications)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_email_password
SMTP_FROM_EMAIL=noreply@vmhlss.local

# Celery Configuration
CELERY_BROKER_URL=redis://redis:6379
CELERY_RESULT_BACKEND=redis://redis:6379
CELERY_TASK_TIME_LIMIT=3600
CELERY_TASK_SOFT_TIME_LIMIT=3000

# GIS Configuration
GDAL_DATA=/usr/share/gdal
PROJ_LIB=/usr/share/proj

# Advanced Configuration
SQLALCHEMY_ECHO=False
TESTING=False
DEBUG=False

# GitHub Actions (for CI/CD)
GITHUB_TOKEN=your_github_token_here

# Optional: S3 Configuration (for storing GIS files)
# AWS_ACCESS_KEY_ID=your_aws_key_here
# AWS_SECRET_ACCESS_KEY=your_aws_secret_here
# AWS_STORAGE_BUCKET_NAME=vmhlss-storage
# AWS_S3_REGION_NAME=us-east-1

# Optional: Sentry Configuration (for error tracking)
# SENTRY_DSN=your_sentry_dsn_here
